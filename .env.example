# ============================================================
#  AI-Powered LaTeX Diagram Generator — Environment Variables
# ============================================================

# --- IBM Cloud Credentials ---
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here
IBM_CLOUD_URL=https://us-south.ml.cloud.ibm.com

# --- IBM Watson Studio / Watsonx.ai Project ---
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# --- Granite Model ID (adjust to your deployed model) ---
# Options: ibm/granite-13b-instruct-v2, ibm/granite-20b-multilingual
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# --- Flask App ---
FLASK_SECRET_KEY=change_this_to_a_secure_random_string
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_PORT=5000

# --- LaTeX Compilation ---
# Options: local (requires pdflatex), tectonic, microservice
LATEX_COMPILER=tectonic
# If using a microservice: LATEX_SERVICE_URL=http://localhost:8080/compile

# --- File Storage ---
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
MAX_CONTENT_LENGTH=16777216

# --- Session / History ---
DIAGRAM_HISTORY_LIMIT=50
